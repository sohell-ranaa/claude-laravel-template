{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "sonnet",
  "alwaysThinkingEnabled": true,
  "permissions": {
    "allow": [
      "Bash(ls *)",
      "Bash(cd *)",
      "Bash(pwd)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(tree *)",
      "Bash(wc *)",
      "Bash(echo *)",
      "Bash(which *)",
      "Bash(git *)",
      "Bash(composer *)",
      "Bash(php artisan *)",
      "Bash(php *)",
      "Bash(npm *)",
      "Bash(yarn *)",
      "Bash(node *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(rm *)",
      "Bash(chmod *)",
      "Bash(diff *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Read",
      "Glob",
      "Grep",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:laravel.com)",
      "WebFetch(domain:livewire.laravel.com)",
      "WebFetch(domain:tailwindcss.com)",
      "WebFetch(domain:packagist.org)"
    ],
    "deny": [
      "Bash(curl *)",
      "Bash(wget *)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(backend/.env)",
      "Read(backend/.env.*)"
    ]
  }
}
